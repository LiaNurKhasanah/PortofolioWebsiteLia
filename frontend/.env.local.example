# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Cloudflare R2 (S3-compatible) ---
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=lia-portfolio
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-domain.com

# --- Admin Auth (HTTP-only signed cookie session) ---
ADMIN_USERNAME=liabocil
ADMIN_PASSWORD=your-secure-password-here
ADMIN_JWT_SECRET=your-jwt-secret-at-least-32-chars
ADMIN_SESSION_SECRET=your-session-secret-at-least-32-chars